page {
  height: 100%;
  background-color: #f5f5f5;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

/* 头部样式 */
.header {
  background-color: #fff;
  padding: 20rpx;
  text-align: center;
  border-bottom: 1rpx solid #eee;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  display: block;
}

.subtitle {
  font-size: 32rpx;
  color: #333;
  display: block;
  margin-top: 10rpx;
}

.phone {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-top: 10rpx;
}

/* 主体内容区 */
.main-content {
  display: flex;
  flex: 1;
  overflow: hidden;
}

/* 左侧导航 */
.sidebar {
  width: 200rpx;
  background-color: #f8f8f8;
  height: 100%;
}

.category-item {
  padding: 30rpx 20rpx;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  border-bottom: 1rpx solid #eee;
}

.category-item.active {
  background-color: #fff;
  color: #e4393c;
  font-weight: bold;
  border-left: 6rpx solid #e4393c;
}

/* 右侧菜品列表 */
.menu-list {
  flex: 1;
  background-color: #fff;
  height: 100%;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 20rpx;
  border-bottom: 1rpx solid #eee;
}

.item-info {
  display: flex;
  flex-direction: column;
}

.item-name {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 10rpx;
}

.item-price {
  font-size: 28rpx;
  color: #e4393c;
  font-weight: bold;
}

.add-btn {
  width: 60rpx !important;
  height: 60rpx !important;
  line-height: 60rpx !important;
  padding: 0 !important;
  margin: 0 !important;
  background-color: #e4393c;
  color: #fff;
  border-radius: 50%;
  font-size: 40rpx;
  text-align: center;
}

/* 底部购物车栏 */
.cart-bar {
  height: 100rpx;
  background-color: #333;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 20rpx;
  position: relative;
  z-index: 100;
}

.cart-info {
  display: flex;
  align-items: center;
  color: #fff;
}

.cart-icon {
  font-size: 50rpx;
  margin-right: 20rpx;
}

.total-price {
  font-size: 36rpx;
  font-weight: bold;
}

.checkout-btn {
  background-color: #e4393c;
  color: #fff;
  height: 70rpx;
  line-height: 70rpx;
  border-radius: 35rpx;
  font-size: 28rpx;
  margin: 0;
}

/* 购物车弹窗 */
.cart-popup {
  position: absolute;
  bottom: 100rpx;
  left: 0;
  width: 100%;
  background-color: #fff;
  z-index: 99;
  box-shadow: 0 -4rpx 10rpx rgba(0,0,0,0.1);
  max-height: 50vh;
  display: flex;
  flex-direction: column;
}

.cart-header {
  display: flex;
  justify-content: space-between;
  padding: 20rpx;
  background-color: #f5f5f5;
  font-size: 28rpx;
  color: #666;
}

.close-btn {
  color: #999;
}

.cart-items {
  flex: 1;
  padding: 0 20rpx;
}

.cart-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}

.cart-item-name {
  flex: 2;
  font-size: 28rpx;
}

.cart-item-price {
  flex: 1;
  color: #e4393c;
  text-align: right;
}

.cart-item-qty {
  flex: 1;
  text-align: right;
  color: #666;
}
