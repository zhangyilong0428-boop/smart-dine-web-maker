.container {
  padding: 20rpx;
  background-color: #fff;
  min-height: 100vh;
}

.item-image {
  width: 100%;
  height: 400rpx;
  border-radius: 10rpx;
  background-color: #f0f0f0; /* 占位色 */
}

.item-name {
  font-size: 40rpx;
  font-weight: bold;
  margin-top: 20rpx;
}

.item-price {
  font-size: 36rpx;
  color: #e4393c;
  margin-top: 10rpx;
  font-weight: bold;
}

.options-section {
  margin-top: 40rpx;
}

.option-group {
  margin-bottom: 30rpx;
}

.option-type {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 10rpx;
}

.option-values {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.option-value {
  padding: 10rpx 30rpx;
  border: 1rpx solid #ccc;
  border-radius: 30rpx;
  font-size: 28rpx;
  color: #666;
}

.option-value.selected {
  background-color: #e4393c;
  color: #fff;
  border-color: #e4393c;
}

.add-to-cart-btn {
  margin-top: 60rpx;
  background-color: #e4393c;
  color: #fff;
  border-radius: 40rpx;
  font-size: 32rpx;
}
